# Ollama (local Docker ¯ default after: docker compose up -d)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_TIMEOUT=300
OLLAMA_CHAT_TIMEOUT=600
OLLAMA_CHAT_RETRIES=2

# GPU: auto (detect NVIDIA) | gpu (force) | cpu (force CPU)
OLLAMA_GPU_MODE=auto

# Optional paths
DOCS_DIR=../docs
CHROMA_DIR=./data/chroma

# Chunking / retrieval
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=5
EMBED_MAX_CHARS=6000
MAX_FULL_DOC_CHARS=60000

# Judge model for eval (defaults to chat model)
OLLAMA_JUDGE_MODEL=llama3.2

# Agent conversationnel + serveur MCP
MCP_HOST=127.0.0.1
MCP_PORT=8010
AGENT_MAX_TOOL_ITERATIONS=5
UPLOADS_DIR=./uploads

# Docker Compose (services mcp-server / ui) ? decommenter si vous lancez tout via compose :
# OLLAMA_BASE_URL=http://ollama:11434
# MCP_SERVER_URL=http://mcp-server:8010/mcp
# DOCS_DIR=/docs
