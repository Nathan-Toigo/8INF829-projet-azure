# Ollama (local Docker — default after: docker compose up -d)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_TIMEOUT=300

# GPU: auto (detect NVIDIA) | gpu (force) | cpu (force CPU)
OLLAMA_GPU_MODE=auto

# Optional paths
DOCS_DIR=../docs
CHROMA_DIR=./data/chroma

# Chunking / retrieval
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=5
