# --- OpenAI ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Tavily (web search MCP tool); optional, agent degrades gracefully if unset ---
TAVILY_API_KEY=

# --- MCP server (standalone HTTP process) ---
MCP_HOST=127.0.0.1
MCP_PORT=8000
# Full URL the agent (MCP client) uses to reach the server.
MCP_SERVER_URL=http://127.0.0.1:8000/mcp

# --- RAG / Chroma (shared on-disk store between UI and MCP server) ---
CHROMA_DIR=.chroma
CHROMA_COLLECTION=patient_records
RAG_TOP_K=4

# --- Shared synthetic patient charts (for the "load sample patient" demo) ---
DOCS_DIR=../docs

# --- Memory layer ---
SHORT_TERM_MAX_TURNS=8
CONTEXT_TOKEN_BUDGET=3000

# --- LangSmith observability (optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=dms-2-clinical-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
