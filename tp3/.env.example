# --- OpenRouter (single key powers chat, vision OCR, and embeddings) ---
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution headers for OpenRouter rankings.
OPENROUTER_APP_URL=http://localhost:8501
OPENROUTER_APP_TITLE=ThreeTokens Care Agent

# Model tiers (see spec section 14).
OPENROUTER_STRONG_MODEL=openai/gpt-4o
OPENROUTER_SMALL_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# --- MongoDB (docker-compose provides this on localhost:27017) ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=threetokens_care

# --- ChromaDB (on-disk persistent store) ---
CHROMA_DIR=./chroma

# --- Shared synthetic patient charts (for the "load sample patient" demo) ---
DOCS_DIR=../docs

# --- Retrieval ---
RAG_TOP_K=5

# --- Agent loop protection ---
MAX_AGENT_STEPS=20
MAX_AGENT_RETRIES=2

# --- LangSmith observability (optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=threetokens-care-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
